{
  "name": "fyle-eslint-plugin",
  "version": "1.0.3",
  "description": "Custom ESLint rules and configurations for Fyle",
  "private": true,
  "exports": {
    ".": "./packages/core/src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fylein/fyle-eslint-plugin.git"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@angular-eslint/utils": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/common": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@types/jest": "^29.0.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@typescript-eslint/rule-tester": "^8.34.0",
    "@typescript-eslint/utils": "^8.34.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^8.0.3",
    "jest": "^29.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "linting",
    "rules"
